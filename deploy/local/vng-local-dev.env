# VoltNueronGrid — local single-node dev environment
# Source this file or export each variable before starting the server.
# Usage: source deploy/local/vng-local-dev.env && /Users/pavanpvj/installs/target/release/voltnuerongridd

# ── Identity ──────────────────────────────────────────────────────────────────
VNG_NODE_ID=node-1
VNG_CLUSTER_MODE=single

# ── HTTP transport (IDE + REST clients) ───────────────────────────────────────
VNG_HTTP_BIND=127.0.0.1:8080

# ── Native transport (native driver path, IDE extension in "native"/"auto") ───
VNG_NATIVE_LISTENER_ENABLED=true
VNG_NATIVE_BIND=127.0.0.1:7542

# ── Auth ──────────────────────────────────────────────────────────────────────
VNG_ADMIN_API_KEY=local-dev-key
# Default operator bindings (built-in): "admin" → Dba, "automation" → Sre
# For SQL/catalog calls from curl: add -H "x-vng-operator-id: admin"

# ── MCP (optional — enables MCP tool proxy to runtime) ───────────────────────
# VNG_MCP_RUNTIME_PROXY=true
# VNG_RUNTIME_BASE_URL=http://127.0.0.1:8080

# ── FTS (optional) ────────────────────────────────────────────────────────────
# VNG_FTS_ENABLED=true
