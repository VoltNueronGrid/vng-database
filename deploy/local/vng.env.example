# vng.env.example — VoltNueronGrid environment variable template
# Document: S11-004
#
# Copy to .env and edit before running the server:
#   cp deploy/local/vng.env.example .env
#   source .env
#
# All variables are optional unless marked [REQUIRED for production].

# ─── HTTP listener ────────────────────────────────────────────────────────────

# TCP port for the HTTP/REST API listener.
# Default: 8080
VNG_HTTP_PORT=8080

# Bind address for the HTTP listener.
# Default: 0.0.0.0 (all interfaces). Use 127.0.0.1 for loopback-only.
VNG_HTTP_BIND=0.0.0.0

# TLS certificate and key for HTTPS. If unset, HTTP is served in plaintext.
# [REQUIRED for production]
# VNG_HTTP_TLS_CERT=/path/to/server.crt
# VNG_HTTP_TLS_KEY=/path/to/server.key

# ─── Native listener (vng:// protocol) ───────────────────────────────────────

# Enable the native TCP listener (vng:// protocol).
# Default: false
VNG_NATIVE_ENABLED=false

# TCP port for the native listener.
# Default: 9090
VNG_NATIVE_PORT=9090

# Bind address for the native listener.
# Default: 0.0.0.0
VNG_NATIVE_BIND=0.0.0.0

# TLS certificate and key for the native listener. If unset, plaintext TCP is used.
# VNG_NATIVE_TLS_CERT=/path/to/native-server.crt
# VNG_NATIVE_TLS_KEY=/path/to/native-server.key

# mTLS: CA certificate to verify client certificates on the native listener.
# When set, clients must present a certificate signed by this CA.
# VNG_NATIVE_MTLS_CA=/path/to/ca.crt

# Bearer token for native listener authentication.
# [REQUIRED for production when VNG_NATIVE_ENABLED=true]
# VNG_NATIVE_BEARER_TOKEN=changeme-replace-with-strong-token

# ─── Authentication ───────────────────────────────────────────────────────────

# Admin API key for administrative operations (e.g. server-status, schema admin).
# [REQUIRED for production]
# VNG_ADMIN_API_KEY=changeme-replace-with-strong-key

# Operator API key for operator-level operations.
# VNG_OPERATOR_API_KEY=

# ─── Data and storage ────────────────────────────────────────────────────────

# Root directory where the engine stores its data files.
# Separate from the engine binary (R-05).
# Default: ./data
VNG_DATA_DIR=./data

# Maximum size of the write-ahead log in MB before rotation.
# Default: 512
# VNG_WAL_MAX_MB=512

# ─── Logging ─────────────────────────────────────────────────────────────────

# Log level: error | warn | info | debug | trace
# Default: info
VNG_LOG_LEVEL=info

# Log format: text | json
# Use json for structured logging in production environments.
# Default: text
VNG_LOG_FORMAT=text

# ─── Runtime tuning ──────────────────────────────────────────────────────────

# Number of worker threads for the async runtime.
# Default: number of logical CPUs
# VNG_WORKER_THREADS=4

# Maximum number of concurrent HTTP connections.
# Default: 1024
# VNG_HTTP_MAX_CONNECTIONS=1024

# Maximum request body size in bytes (HTTP ingest endpoints).
# Default: 104857600 (100 MB)
# VNG_HTTP_MAX_BODY_BYTES=104857600

# ─── Multi-node / HA ─────────────────────────────────────────────────────────

# Node ID for this instance in a multi-node cluster.
# Default: node-0 (single-node mode)
# VNG_NODE_ID=node-0

# Comma-separated list of peer addresses for Raft consensus.
# Leave empty for single-node operation.
# VNG_RAFT_PEERS=127.0.0.1:9191,127.0.0.1:9192

# Shared secret for authenticating intra-cluster Raft RPCs (AppendEntries, RequestVote).
# All nodes in the cluster must use the same value.
# VNG_CLUSTER_TOKEN=changeme-replace-with-strong-secret

# This node's own advertised base URL (scheme + host + port, no trailing slash).
# The leader broadcasts this value to followers via the x-vng-leader-url header on every
# AppendEntries RPC. Followers use it to transparently forward DML writes to the leader.
# Required in multi-node clusters; unused in single-node mode.
# VNG_NODE_URL=http://node0.internal:8080

# ─── Process management ──────────────────────────────────────────────────────

# Path to write the server PID file.
# Used by install.sh to track and stop the process.
# Default: /tmp/voltnuerongridd.pid
VNG_PID_FILE=/tmp/voltnuerongridd.pid
