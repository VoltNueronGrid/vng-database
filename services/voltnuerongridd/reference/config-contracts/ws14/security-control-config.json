{
  "security": {
    "adminApiKeyEnv": "VNG_ADMIN_API_KEY",
    "adminHeaderName": "x-vng-admin-key",
    "tlsRequired": true,
    "mtlsRequired": false,
    "encryptionAtRestRequired": true,
    "kmsKeyRefEnv": "VNG_KMS_KEY_URI",
    "kmsFailoverKeyRefEnvs": [
      "VNG_KMS_KEY_URI_REGION_B",
      "VNG_KMS_KEY_URI_REGION_C"
    ],
    "allowedOperatorRoles": [
      "dba",
      "sre"
    ],
    "tokenTtlSeconds": 300
  }
}
