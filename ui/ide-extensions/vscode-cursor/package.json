{
  "name": "voltnuerongrid-vscode-cursor",
  "displayName": "VoltNueronGrid Tools (VSCode/Cursor)",
  "description": "Professional database client for VoltNueronGrid DB with connection management, SQL editor, and database explorer",
  "version": "0.3.2",
  "publisher": "voltnuerongrid",
  "repository": {
    "type": "git",
    "url": "https://github.com/Pavan-Pvj_ghub/polap-db.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "categories": [
    "Other"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": true
    },
    "virtualWorkspaces": {
      "supported": true
    }
  },
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vngExplorer",
          "title": "VoltNueronGrid",
          "icon": "media/volt-neuron-grid.svg"
        }
      ]
    },
    "views": {
      "vngExplorer": [
        {
          "id": "vngDatabaseExplorer",
          "name": "Database",
          "icon": "media/database.svg"
        },
        {
          "id": "vngQueryHistory",
          "name": "Query History"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "vngDatabaseExplorer",
        "contents": "You have not created any connections yet.\n\n[Create Connection](command:vng.newConnection)\n\n[Manage Connections](command:vng.manageConnections) lists, tests, and edits saved profiles."
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "vng.newConnection",
          "when": "view == vngDatabaseExplorer",
          "group": "navigation@1"
        },
        {
          "command": "vng.refreshSchema",
          "when": "view == vngDatabaseExplorer",
          "group": "navigation@2"
        },
        {
          "command": "vng.manageConnections",
          "when": "view == vngDatabaseExplorer",
          "group": "navigation@3"
        },
        {
          "command": "vng.testConnection",
          "when": "view == vngDatabaseExplorer",
          "group": "navigation@4"
        },
        {
          "command": "vng.refreshQueryHistory",
          "when": "view == vngQueryHistory",
          "group": "navigation@1"
        },
        {
          "command": "vng.searchQueryHistory",
          "when": "view == vngQueryHistory",
          "group": "navigation@2"
        },
        {
          "command": "vng.clearQueryHistory",
          "when": "view == vngQueryHistory",
          "group": "navigation@3"
        }
      ],
      "editor/title": [
        {
          "command": "vng.sql.executeSelectionOrFile",
          "when": "resourceExtname == .sql",
          "group": "navigation@1"
        },
        {
          "command": "vng.sql.analyzeSelectionOrFile",
          "when": "resourceExtname == .sql",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "vng.connectConnection",
          "when": "view == vngDatabaseExplorer && viewItem == connectionInactive",
          "group": "0_connection@1"
        },
        {
          "command": "vng.disconnectConnection",
          "when": "view == vngDatabaseExplorer && viewItem == connectionActive",
          "group": "0_connection@1"
        },
        {
          "command": "vng.editConnection",
          "when": "view == vngDatabaseExplorer && (viewItem == connectionActive || viewItem == connectionInactive)",
          "group": "0_connection@2"
        },
        {
          "command": "vng.testConnection",
          "when": "view == vngDatabaseExplorer && (viewItem == connectionActive || viewItem == connectionInactive)",
          "group": "0_connection@3"
        },
        {
          "command": "vng.deleteConnection",
          "when": "view == vngDatabaseExplorer && (viewItem == connectionActive || viewItem == connectionInactive)",
          "group": "0_connection@4"
        },
        {
          "command": "vng.copyName",
          "when": "view == vngDatabaseExplorer && (viewItem == table || viewItem == column)",
          "group": "1_modification@1"
        },
        {
          "command": "vng.createTableWizard",
          "when": "view == vngDatabaseExplorer && viewItem == schema",
          "group": "1_modification@2"
        },
        {
          "command": "vng.openTableEditor",
          "when": "view == vngDatabaseExplorer && viewItem == table",
          "group": "1_modification@3"
        },
        {
          "command": "vng.alterTableWizard",
          "when": "view == vngDatabaseExplorer && viewItem == table",
          "group": "2_queries@0"
        },
        {
          "command": "vng.showTableDDL",
          "when": "view == vngDatabaseExplorer && viewItem == table",
          "group": "2_queries@1"
        },
        {
          "command": "vng.generateMockData",
          "when": "view == vngDatabaseExplorer && viewItem == table",
          "group": "2_queries@3"
        },
        {
          "command": "vng.dumpTableStruct",
          "when": "view == vngDatabaseExplorer && viewItem == table",
          "group": "3_export@1"
        },
        {
          "command": "vng.dropTable",
          "when": "view == vngDatabaseExplorer && viewItem == table",
          "group": "4_danger@1"
        },
        {
          "command": "vng.reRunHistoryQuery",
          "when": "view == vngQueryHistory && viewItem == historyEntry",
          "group": "inline@1"
        },
        {
          "command": "vng.copyConnectionHost",
          "when": "view == vngDatabaseExplorer && (viewItem == connectionActive || viewItem == connectionInactive)",
          "group": "0_connection@5"
        },
        {
          "command": "vng.showConnectionStatus",
          "when": "view == vngDatabaseExplorer && (viewItem == connectionActive || viewItem == connectionInactive)",
          "group": "0_connection@6"
        },
        {
          "command": "vng.showConnectionHistory",
          "when": "view == vngDatabaseExplorer && (viewItem == connectionActive || viewItem == connectionInactive)",
          "group": "0_connection@7"
        },
        {
          "command": "vng.importSqlFile",
          "when": "view == vngDatabaseExplorer && (viewItem == connectionActive || viewItem == connectionInactive)",
          "group": "0_connection@8"
        },
        {
          "command": "vng.dumpTableData",
          "when": "view == vngDatabaseExplorer && viewItem == table",
          "group": "3_export@2"
        },
        {
          "command": "vng.truncateTable",
          "when": "view == vngDatabaseExplorer && viewItem == table",
          "group": "4_danger@2"
        },
        {
          "command": "vng.copyColumnName",
          "when": "view == vngDatabaseExplorer && viewItem == column",
          "group": "1_modification@1"
        },
        {
          "command": "vng.copyColumnDefinition",
          "when": "view == vngDatabaseExplorer && viewItem == column",
          "group": "1_modification@2"
        },
        {
          "command": "vng.addColumnWizard",
          "when": "view == vngDatabaseExplorer && (viewItem == table || viewItem == column)",
          "group": "1_modification@4"
        }
      ]
    },
    "commands": [
      {
        "command": "vng.testConnection",
        "title": "VoltNueronGrid: Test Connection",
        "icon": "$(vm-running)",
        "category": "VoltNueronGrid"
      },
      {
        "command": "vng.manageConnections",
        "title": "VoltNueronGrid: Manage Connections",
        "icon": "$(list-unordered)",
        "category": "VoltNueronGrid"
      },
      {
        "command": "vng.newConnection",
        "title": "VoltNueronGrid: Create New Connection",
        "icon": "$(add)",
        "category": "VoltNueronGrid"
      },
      {
        "command": "vng.editConnection",
        "title": "VoltNueronGrid: Edit Connection",
        "category": "VoltNueronGrid"
      },
      {
        "command": "vng.connectConnection",
        "title": "VoltNueronGrid: Connect Connection",
        "category": "VoltNueronGrid"
      },
      {
        "command": "vng.disconnectConnection",
        "title": "VoltNueronGrid: Disconnect Connection",
        "category": "VoltNueronGrid"
      },
      {
        "command": "vng.deleteConnection",
        "title": "VoltNueronGrid: Delete Connection",
        "category": "VoltNueronGrid"
      },
      {
        "command": "vng.quickSwitchConnection",
        "title": "VoltNueronGrid: Quick Switch Connection"
      },
      {
        "command": "vng.runQuery",
        "title": "VoltNueronGrid: Run Query"
      },
      {
        "command": "vng.cancelActiveQuery",
        "title": "VoltNueronGrid: Cancel Active Query"
      },
      {
        "command": "vng.showQueryResults",
        "title": "VoltNueronGrid: Show Query Results"
      },
      {
        "command": "vng.refreshQueryHistory",
        "title": "VoltNueronGrid: Refresh Query History",
        "icon": "$(refresh)",
        "category": "VoltNueronGrid"
      },
      {
        "command": "vng.searchQueryHistory",
        "title": "VoltNueronGrid: Search Query History",
        "icon": "$(search)",
        "category": "VoltNueronGrid"
      },
      {
        "command": "vng.clearQueryHistory",
        "title": "VoltNueronGrid: Clear Query History",
        "icon": "$(trash)",
        "category": "VoltNueronGrid"
      },
      {
        "command": "vng.reRunHistoryQuery",
        "title": "VoltNueronGrid: Re-run History Query",
        "category": "VoltNueronGrid"
      },
      {
        "command": "vng.analyzeQuery",
        "title": "VoltNueronGrid: Analyze Query"
      },
      {
        "command": "vng.showSchemaRegistry",
        "title": "VoltNueronGrid: Show Schema Registry"
      },
      {
        "command": "vng.focusPanel",
        "title": "VoltNueronGrid: Focus Panel"
      },
      {
        "command": "vng.refreshSchema",
        "title": "Refresh Schema",
        "icon": "$(refresh)",
        "category": "VoltNueronGrid"
      },
      {
        "command": "vng.copyName",
        "title": "Copy Name",
        "category": "VoltNueronGrid"
      },
      {
        "command": "vng.openTableEditor",
        "title": "Open Table Editor",
        "category": "VoltNueronGrid"
      },
      {
        "command": "vng.openTableEditorPicker",
        "title": "Open Table Editor (Pick Table)",
        "category": "VoltNueronGrid"
      },
      {
        "command": "vng.createTableWizard",
        "title": "Create Table Wizard",
        "category": "VoltNueronGrid"
      },
      {
        "command": "vng.alterTableWizard",
        "title": "Alter Table Wizard",
        "category": "VoltNueronGrid"
      },
      {
        "command": "vng.tableEditor.save",
        "title": "Table Editor: Save",
        "category": "VoltNueronGrid"
      },
      {
        "command": "vng.tableEditor.addRow",
        "title": "Table Editor: Add Row",
        "category": "VoltNueronGrid"
      },
      {
        "command": "vng.tableEditor.discard",
        "title": "Table Editor: Discard Changes",
        "category": "VoltNueronGrid"
      },
      {
        "command": "vng.tableEditor.refresh",
        "title": "Table Editor: Refresh",
        "category": "VoltNueronGrid"
      },
      {
        "command": "vng.showTableDDL",
        "title": "Show DDL",
        "category": "VoltNueronGrid"
      },
      {
        "command": "vng.showSQLTemplate",
        "title": "SQL Template",
        "category": "VoltNueronGrid"
      },
      {
        "command": "vng.generateMockData",
        "title": "Generate Mock Data",
        "category": "VoltNueronGrid"
      },
      {
        "command": "vng.dumpTableStruct",
        "title": "Dump Structure",
        "category": "VoltNueronGrid"
      },
      {
        "command": "vng.dropTable",
        "title": "Drop Table",
        "category": "VoltNueronGrid"
      },
      {
        "command": "vng.sql.executeSelectionOrFile",
        "title": "VoltNueronGrid: Execute SQL (Selection/File)",
        "category": "VoltNueronGrid",
        "icon": "$(run)"
      },
      {
        "command": "vng.sql.analyzeSelectionOrFile",
        "title": "VoltNueronGrid: Analyze SQL (Selection/File)",
        "category": "VoltNueronGrid",
        "icon": "$(search)"
      },
      {
        "command": "vng.openSettings",
        "title": "VoltNueronGrid: Settings",
        "category": "VoltNueronGrid"
      },
      {
        "command": "vng.copyConnectionHost",
        "title": "Copy Host:Port",
        "category": "VoltNueronGrid"
      },
      {
        "command": "vng.showConnectionStatus",
        "title": "Show Connection Status",
        "category": "VoltNueronGrid"
      },
      {
        "command": "vng.showConnectionHistory",
        "title": "Show Connection History",
        "category": "VoltNueronGrid"
      },
      {
        "command": "vng.importSqlFile",
        "title": "Import SQL File…",
        "category": "VoltNueronGrid"
      },
      {
        "command": "vng.dumpTableData",
        "title": "Dump Table Data",
        "category": "VoltNueronGrid"
      },
      {
        "command": "vng.truncateTable",
        "title": "Truncate Table…",
        "category": "VoltNueronGrid"
      },
      {
        "command": "vng.copyColumnName",
        "title": "Copy Column Name",
        "category": "VoltNueronGrid"
      },
      {
        "command": "vng.copyColumnDefinition",
        "title": "Copy Column Definition",
        "category": "VoltNueronGrid"
      },
      {
        "command": "vng.addColumnWizard",
        "title": "Add Column…",
        "category": "VoltNueronGrid"
      }
    ],
    "keybindings": [
      {
        "command": "vng.sql.executeSelectionOrFile",
        "key": "ctrl+enter",
        "when": "editorTextFocus && resourceExtname == .sql"
      },
      {
        "command": "vng.sql.analyzeSelectionOrFile",
        "key": "ctrl+shift+enter",
        "when": "editorTextFocus && resourceExtname == .sql"
      },
      {
        "command": "vng.quickSwitchConnection",
        "key": "ctrl+shift+d",
        "when": "editorTextFocus || explorerViewletVisible"
      },
      {
        "command": "vng.openTableEditorPicker",
        "key": "ctrl+shift+f",
        "when": "focusedView == vngDatabaseExplorer"
      },
      {
        "command": "vng.createTableWizard",
        "key": "ctrl+alt+c",
        "when": "focusedView == vngDatabaseExplorer"
      },
      {
        "command": "vng.tableEditor.save",
        "key": "ctrl+s",
        "when": "activeWebviewPanelId == vngTableEditor"
      },
      {
        "command": "vng.tableEditor.addRow",
        "key": "ctrl+shift+n",
        "when": "activeWebviewPanelId == vngTableEditor"
      },
      {
        "command": "vng.tableEditor.refresh",
        "key": "ctrl+r",
        "when": "activeWebviewPanelId == vngTableEditor"
      },
      {
        "command": "vng.tableEditor.discard",
        "key": "escape",
        "when": "activeWebviewPanelId == vngTableEditor"
      },
      {
        "command": "vng.openSettings",
        "key": "ctrl+,",
        "when": "focusedView == vngDatabaseExplorer || editorTextFocus"
      }
    ],
    "configuration": {
      "title": "VoltNueronGrid",
      "properties": {
        "voltnuerongrid.baseUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8080",
          "description": "Base URL for the VoltNueronGrid runtime service"
        },
        "voltnuerongrid.transportMode": {
          "type": "string",
          "enum": ["http", "native", "auto"],
          "default": "auto",
          "description": "Preferred transport for the extension (`auto` follows scheme + dual-endpoint settings; HTTP remains the default data-plane until the TS native client is fully integrated)."
        },
        "voltnuerongrid.nativeEndpoint": {
          "type": "string",
          "default": "",
          "description": "Optional native wire endpoint (e.g. vng://127.0.0.1:7542) used when transportMode is native or auto."
        },
        "voltnuerongrid.sql.runOnSave": {
          "type": "string",
          "enum": [
            "never",
            "prompt",
            "always"
          ],
          "default": "prompt",
          "description": "Run SQL automatically when a .sql file is saved"
        },
        "voltnuerongrid.sql.runOnOpen": {
          "type": "string",
          "enum": [
            "never",
            "prompt",
            "always"
          ],
          "default": "never",
          "description": "Run SQL automatically when a .sql file is opened"
        },
        "voltnuerongrid.schema.cache.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable caching for schema registry data"
        },
        "voltnuerongrid.schema.cache.ttlSeconds": {
          "type": "number",
          "default": 300,
          "minimum": 5,
          "description": "Schema cache time-to-live in seconds"
        },
        "voltnuerongrid.query.cache.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable in-memory cache for successful query results"
        },
        "voltnuerongrid.query.cache.ttlSeconds": {
          "type": "number",
          "default": 30,
          "minimum": 1,
          "description": "Query result cache time-to-live in seconds"
        },
        "voltnuerongrid.query.cache.maxEntries": {
          "type": "number",
          "default": 100,
          "minimum": 1,
          "description": "Maximum cached successful query results"
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p ./",
    "test": "npm run build && node --test out/test/**/*.test.js",
    "benchmark:startup": "npm run build && node ./tools/benchmark-startup.js --runs 10",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --allow-missing-repository"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^2.30.0",
    "typescript": "^5.5.4"
  }
}
