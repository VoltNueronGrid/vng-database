{
  "compilerOptions": {
    "module": "commonjs",
    "target": "es2020",
    "lib": [
      "es2020",
      "dom"
    ],
    "outDir": "out",
    "rootDir": "src",
    "strict": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "types": [
      "node"
    ],
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@voltnuerongrid/driver-typescript": [
        "../../../drivers/voltnuerongrid-driver-typescript/dist/index"
      ]
    }
  },
  "include": [
    "src/**/*.ts"
  ]
}
