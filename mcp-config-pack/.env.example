# VoltNueronGrid MCP env template
# Copy to your shell profile or client-specific env section.

# Admin key for admin-level MCP tool calls
VNG_ADMIN_API_KEY=secret

# Optional bind for local service route adapters
VNG_HTTP_BIND=127.0.0.1:8080

# Optional logging and policy knobs
VNG_MCP_LOG_LEVEL=info
VNG_MCP_REQUEST_TIMEOUT_S=30
VNG_MCP_MAX_QUERY_SIZE_KB=64
VNG_MCP_MAX_RESULT_SIZE_KB=10

# Optional auth headers for operator/tenant flows
# x-vng-operator-id is usually sent per request payload
# x-vng-tenant-id and x-vng-user-id are usually sent per request payload
